{
  "name": "forge-sutra",
  "version": "1.0.0",
  "description": "Static structural graph tool for JS/TS repos. Writes graph.json + HTML view + drift checks. v1.0.",
  "type": "module",
  "bin": {
    "forge-sutra": "./dist/cli.js",
    "sutra": "./dist/cli.js"
  },
  "files": [
    "dist",
    "viewer",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "sutra": "node dist/cli.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ts-morph": "^23.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sbknext/forge-sutra"
  },
  "keywords": [
    "sutra",
    "forge",
    "static-analysis",
    "typescript",
    "graph"
  ]
}
